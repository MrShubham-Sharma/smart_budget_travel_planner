# Generate your own key with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY='a_very_strong_random_secret_key_e.g._4fa2c62c3f8e5f7a'
FLASK_DEBUG=True
# Optional: a public Hugging Face model is also attempted automatically.
# If you have a token, set it here for higher reliability.
HF_API_KEY=your_huggingface_api_token_here

# PostgreSQL connection string (for local dev — leave blank to use SQLite fallback)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# On Render: this is set automatically in Environment Variables — do NOT put it here
DATABASE_URL=